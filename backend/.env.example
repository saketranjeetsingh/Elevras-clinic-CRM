# Copy this file to .env and fill in the real values. DO NOT commit the real .env file.
# Example values below — replace with your own credentials when running locally.

# Postgres connection in SQLAlchemy URL form:
# postgresql://<username>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:password@localhost:5432/elevras_db

# Secret key used for signing tokens. Use a long random string in production.
SECRET_KEY=your-secret-key-here
